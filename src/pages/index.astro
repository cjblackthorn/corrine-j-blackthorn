---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import { assets } from '../data/assets';
import { links, ventureCards } from '../data/links';
---
<MainLayout title="Corrine J Blackthorn">
  <Hero image={assets.hero} />

  <section>
    <div class="container split">
      <div class="portrait-frame">
        <img src={assets.portraits[0]} alt="Corrine J Blackthorn" />
      </div>
      <div>
        <span class="kicker">About Corrine</span>
        <h2>Technology, creativity, and compassion.</h2>
        <p>I build systems, create art, tell stories, and cultivate spaces where people can grow.</p>
        <p>This site is the personal hub for my technology work, photography, writing, music, advocacy, baking, and the wider Blackthorn ecosystem.</p>
        <a class="button" href="/about/">Read my story</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-heading">
        <span class="kicker">Ventures</span>
        <h2>Connected work. Different doors.</h2>
        <p>Each venture has its own purpose, but they share the same roots: compassion, creativity, learning, and support.</p>
      </div>
      <div class="link-list">
        {ventureCards.map((venture) => <a class="link-card" href={venture.href}><h3>{venture.title}</h3><p>{venture.description}</p></a>)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-heading">
        <span class="kicker">Photography</span>
        <h2>A glimpse through the lens.</h2>
        <p>Quiet moments, changing light, landscapes, food, people, and the beauty hidden in everyday places.</p>
      </div>
      <div class="gallery">
        {assets.photography.slice(0, 6).map((src) => <figure><img src={src} alt="Photography by Corrine J Blackthorn" loading="lazy" /></figure>)}
      </div>
      <p style="margin-top: 24px"><a class="button" href="/photography/">View the gallery</a> <a class="button" href={links.ventures.petalAndFrame}>Visit Petal & Frame</a></p>
    </div>
  </section>

  <section class="quote-band">
    <div class="container">
      <blockquote>Helping people feel seen, inspired, and curious.</blockquote>
    </div>
  </section>

  <section>
    <div class="container split">
      <div>
        <span class="kicker">Music</span>
        <h2>Glass & Thorns</h2>
        <p>Music born from transformation, resilience, identity, and self-discovery.</p>
        <p>Listen to Glass & Thorns on Spotify, Apple Music, and YouTube.</p>
        <div class="hero-actions">
          <a class="button" href={links.music.spotify}>Spotify</a>
          <a class="button" href={links.music.appleMusic}>Apple Music</a>
          <a class="button" href={links.music.youtube}>YouTube</a>
        </div>
      </div>
      <div class="image-frame"><img src={assets.branding[0]} alt="Glass and Thorns branding" loading="lazy" /></div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-heading">
        <span class="kicker">Explore</span>
        <h2>What I build and create.</h2>
        <p>Different forms of work, one connected ecosystem.</p>
      </div>
      <div class="grid">
        <article class="card"><h3>Technology</h3><p>Identity, security, governance, consulting, and practical problem solving.</p><a class="button" href="/technology/">Explore</a></article>
        <article class="card"><h3>Writing</h3><p>Essays, memoir, field notes, reflections, and future KDP releases.</p><a class="button" href="/writing/">Read</a></article>
        <article class="card"><h3>Advocacy</h3><p>Community-centered work for access, dignity, trans rights, disability rights, and support.</p><a class="button" href="/advocacy/">Learn</a></article>
      </div>
    </div>
  </section>
</MainLayout>
