---
import MainLayout from '../layouts/MainLayout.astro';
import { links } from '../data/links';
---
<MainLayout title="Writing | Corrine J Blackthorn">
  <section>
    <div class="container">
      <div class="section-heading">
        <span class="kicker">Writing</span>
        <h1>Stories, essays, field notes, and books.</h1>
        <p>I write to help people see, understand, question, and feel less alone.</p>
      </div>
      <div class="grid">
        <article class="card"><h3>All of Me</h3><p>A memoir in progress about identity, survival, transparency, resilience, and becoming whole.</p><a class="button" href={links.ventures.blackthornFieldNotes}>Updates</a></article>
        <article class="card"><h3>Blackthorn Field Notes</h3><p>Essays, reflections, technical notes, advocacy writing, observations, and long-form work.</p><a class="button" href={links.ventures.blackthornFieldNotes}>Visit Field Notes</a></article>
        <article class="card"><h3>KDP Releases</h3><p>Future books and publications will appear here once they are live.</p><a class="button" href="/writing/">Coming soon</a></article>
      </div>
    </div>
  </section>
  <section class="quote-band"><div class="container"><blockquote>I write what people need to see and understand.</blockquote></div></section>
  <section><div class="container"><div class="section-heading"><span class="kicker">Themes</span><h2>What I return to.</h2><p>Identity, technology, trauma, compassion, community, systems, belonging, and the courage to be honest.</p></div></div></section>
</MainLayout>
