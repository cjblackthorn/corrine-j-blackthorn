---
import MainLayout from '../layouts/MainLayout.astro';
import { links } from '../data/links';
import { assets } from '../data/assets';
---
<MainLayout title="Music | Corrine J Blackthorn">
  <section>
    <div class="container split">
      <div>
        <span class="kicker">Glass & Thorns</span>
        <h1>Music</h1>
        <p>Glass & Thorns is my artist project for music shaped by transformation, identity, resilience, and self-discovery.</p>
        <p>My Body Isn't Home Anymore is available on major streaming platforms.</p>
        <div class="hero-actions">
          <a class="button" href={links.music.spotify}>Spotify</a>
          <a class="button" href={links.music.appleMusic}>Apple Music</a>
          <a class="button" href={links.music.youtube}>YouTube</a>
        </div>
      </div>
      <div class="image-frame"><img src={assets.branding[0]} alt="Glass and Thorns branding" loading="lazy" /></div>
    </div>
  </section>
  <section class="quote-band"><div class="container"><blockquote>Art gives language to the parts of us that survived before we had words.</blockquote></div></section>
  <section><div class="container"><div class="section-heading"><span class="kicker">Listen</span><h2>Find Glass & Thorns online.</h2><p>Follow the artist project for releases, videos, and future creative work.</p></div><div class="grid"><article class="card"><h3>Spotify</h3><p>Stream the latest Glass & Thorns releases.</p><a class="button" href={links.music.spotify}>Open Spotify</a></article><article class="card"><h3>Apple Music</h3><p>Listen through Apple Music.</p><a class="button" href={links.music.appleMusic}>Open Apple Music</a></article><article class="card"><h3>YouTube</h3><p>Watch and follow on YouTube.</p><a class="button" href={links.music.youtube}>Open YouTube</a></article></div></div></section>
</MainLayout>
